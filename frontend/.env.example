# ===============================
# Auth0 Configuration
# ===============================

# Your Auth0 domain
# Example: dev-abc123.us.auth0.com
VITE_AUTH0_DOMAIN=your-auth0-domain.us.auth0.com

# Your Auth0 Application (Client) ID
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# API identifier (Audience) configured in Auth0
# Example: https://api.your-app.com
VITE_AUTH0_AUDIENCE=https://api.your-app.com

# Base URL of frontend application
# Local: http://localhost:3000
# Prod : https://your-frontend-domain.com
VITE_APP_BASE_URL=http://localhost:3000


# ===============================
# Backend API Configuration
# ===============================

# Base URL of backend API
# Local: http://localhost:8080/api
# Prod : https://api.your-app.com
VITE_API_URL=http://localhost:8080/api