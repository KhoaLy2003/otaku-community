                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This comment has been updated via Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interactions/comments/{{testCommentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "comments", "{{testCommentId}}"]
            },
            "description": "Update user's own comment"
          },
          "response": []
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interactions/comments/{{testCommentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "comments", "{{testCommentId}}"]
            },
            "description": "Delete user's own comment (soft delete)"
          },
          "response": []
        },
        {
          "name": "Get Comment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interactions/comments/{{testCommentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "comments", "{{testCommentId}}"]
            },
            "description": "Get a specific comment by ID"
          },
          "response": []
        },
        {
          "name": "Get Post Comments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interactions/posts/{{testPostId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "posts", "{{testPostId}}", "comments"]
            },
            "description": "Get all comments for a post"
          },
          "response": []
        },
        {
          "name": "Get Post Comments (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interactions/posts/{{testPostId}}/comments/paginated?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "posts", "{{testPostId}}", "comments", "paginated"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            },
            "description": "Get comments for a post with pagination"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Topics API",
