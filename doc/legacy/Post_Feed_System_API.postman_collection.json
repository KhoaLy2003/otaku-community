    {
      "name": "Media API",
      "item": [
        {
          "name": "Upload Media",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select an image or video file (JPEG, PNG, GIF, WebP, MP4 - max 5MB)"
                }
              ]
            },
            "url": {
              "raw": "{{mediaBaseUrl}}/upload",
              "host": ["{{mediaBaseUrl}}"],
              "path": ["upload"]
            },
            "description": "Upload a media file to Cloudinary"
          },
          "response": []
        },
        {
          "name": "Delete Media",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{mediaBaseUrl}}/sample-public-id",
              "host": ["{{mediaBaseUrl}}"],
              "path": ["sample-public-id"]
            },
            "description": "Delete a media file by its public ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Test Scenarios",
      "item": [
        {
          "name": "Guest Access - Explore Feed",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{baseUrl}}/feed/explore",
              "host": ["{{baseUrl}}"],
              "path": ["feed", "explore"]
            },
            "description": "Test guest access to explore feed (should work without auth)"
          },
          "response": []
        },
        {
          "name": "Guest Access - Try to Like (Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postId\": \"{{testPostId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interactions/likes",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "likes"]
            },
            "description": "Test guest trying to like a post (should return 401)"
          },
          "response": []
        },
        {
          "name": "Invalid Data - Create Post with Empty Title",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"content\": \"This should fail due to empty title\",\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Test validation error for empty title (should return 400)"
          },
          "response": []
        },
        {
          "name": "Not Found - Get Non-existent Post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Test 404 error for non-existent post"
          },
          "response": []
        }
