{
  "info": {
    "name": "Post and Feed System API",
    "description": "Comprehensive API collection for testing the Post and Feed System including posts, feeds, interactions, topics, and media uploads.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "mediaBaseUrl",
      "value": "http://localhost:8080/media",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "testUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testPostId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testTopicId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testCommentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Posts API",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Test Post\",\n  \"content\": \"This is a test post created via Postman\",\n  \"mediaUrls\": [],\n  \"topicIds\": [],\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Create a new post with title, content, media URLs, and topics"
          },
          "response": []
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{testPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{testPostId}}"]
            },
            "description": "Retrieve a specific post by its ID"
          },
          "response": []
        },
        {
          "name": "Get Post Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{testPostId}}/detail",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{testPostId}}", "detail"]
            },
            "description": "Get complete post details including comments, topics, and like status"
          },
          "response": []
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Post Title\",\n  \"content\": \"This post has been updated via Postman\",\n  \"mediaUrls\": [],\n  \"topicIds\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{testPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{testPostId}}"]
            },
            "description": "Update an existing post (owner only)"
          },
          "response": []
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{testPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{testPostId}}"]
            },
            "description": "Soft delete a post (owner only)"
          },
          "response": []
        },
        {
          "name": "Get Published Posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?page=1&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            },
            "description": "Get all published posts with pagination"
          },
          "response": []
        },
        {
          "name": "Get Posts by User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/user/{{testUserId}}?page=1&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "user", "{{testUserId}}"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            },
            "description": "Get posts by a specific user"
          },
          "response": []
        },
        {
          "name": "Publish Post",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{testPostId}}/publish",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{testPostId}}", "publish"]
            },
            "description": "Publish a draft post"
          },
          "response": []
        },
        {
          "name": "Convert to Draft",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{testPostId}}/draft",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{testPostId}}", "draft"]
            },
            "description": "Convert a published post back to draft"
          },
          "response": []
        },
        {
          "name": "Check Post Ownership",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{testPostId}}/owner",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{testPostId}}", "owner"]
            },
            "description": "Check if current user owns the post"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Feed API",
      "item": [
        {
          "name": "Get Home Feed",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/feed/home?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["feed", "home"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Get personalized home feed for authenticated user"
          },
          "response": []
        },
        {
          "name": "Get Explore Feed",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/feed/explore?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["feed", "explore"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Get public explore feed with all published posts"
          },
          "response": []
        },
        {
          "name": "Get Topic Feed",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/feed/topic/{{testTopicId}}?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["feed", "topic", "{{testTopicId}}"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Get feed for a specific topic"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Interactions API",
      "item": [
        {
          "name": "Like Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postId\": \"{{testPostId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interactions/likes",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "likes"]
            },
            "description": "Like a post"
          },
          "response": []
        },
        {
          "name": "Unlike Post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interactions/likes/{{testPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "likes", "{{testPostId}}"]
            },
            "description": "Remove like from a post"
          },
          "response": []
        },
        {
          "name": "Get Like Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interactions/likes/{{testPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "likes", "{{testPostId}}"]
            },
            "description": "Get like status for a post"
          },
          "response": []
        },
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
